{
    "name": "veilarbvisittkortfs",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "vite --mode mock",
        "dev": "vite --mode mock",
        "build": "tsc && vite build",
        "build:dev": "tsc && NODE_ENV=development vite build",
        "build:mock": "tsc && vite build --mode mock --base=/veilarbvisittkortfs/",
        "serve": "vite preview",
        "test": "vitest",
        "prettier": "prettier --write 'src/**/*.ts{,x}'",
        "lint": "eslint src",
        "prepare": "husky",
        "tsc": "tsc"
    },
    "browserslist": [
        ">0.2%",
        "not dead",
        "not ie < 11",
        "not op_mini all"
    ],
        "lint-staged": {
        "src/**/*.{ts,tsx}": [
            "prettier --write",
            "eslint --config eslint.config.lintstaged.js"
        ]
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.10.1",
        "@navikt/ds-css": "8.10.1",
        "@navikt/ds-react": "8.10.1",
        "@navikt/ds-tailwind": "8.10.1",
        "@navikt/navspa": "7.4.0",
        "@tailwindcss/vite": "4.2.2",
        "axios": "1.15.1",
        "classnames": "2.5.1",
        "dayjs": "1.11.20",
        "formik": "2.4.9",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "swr": "2.4.1",
        "tailwindcss": "4.2.2",
        "zustand": "5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "9.39.1",
        "@testing-library/react": "16.3.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.3",
        "cross-env": "10.1.0",
        "eslint": "9.39.1",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "eslint-plugin-react-hooks": "7.0.1",
        "globals": "16.5.0",
        "husky": "9.1.7",
        "jsdom": "26.1.0",
        "less": "4.6.4",
        "lint-staged": "16.4.0",
        "msw": "2.10.5",
        "prettier": "3.6.2",
        "typescript": "5.9.2",
        "typescript-eslint": "8.46.3",
        "vite": "7.3.2",
        "vite-plugin-svgr": "4.5.0",
        "vitest": "3.2.4"
    },
    "msw": {
        "workerDirectory": "public"
    }
}
